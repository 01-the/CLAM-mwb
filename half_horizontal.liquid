<style>
  .mwb { font-family: inherit; color: #000; }
  .mwb-header { border-bottom: 2px solid #000; padding-bottom: 5px; margin-bottom: 8px; }
  .mwb-header .mwb-week { font-size: 18px; font-weight: 700; display: block; }
  .mwb-header .mwb-reading { font-size: 12px; font-style: italic; }
  .mwb-songs { font-size: 11px; margin-bottom: 8px; }
  .mwb-section { margin-bottom: 10px; }
  .mwb-section h3 { font-size: 11px; text-transform: uppercase; letter-spacing: 0.02em;
    border-bottom: 1px solid #000; padding-bottom: 2px; margin: 0 0 5px 0; }
  .mwb-item { font-size: 12px; line-height: 1.3; margin-bottom: 4px; }
  .mwb-num { font-weight: 700; }
  .mwb-item-time { font-size: 10px; }
</style>

<div class="layout">
  <div class="mwb">
    <div class="mwb-header">
      <span class="mwb-week">{{ week_label }}</span>
      <span class="mwb-reading">{{ bible_reading }}</span>
    </div>
    <div class="mwb-songs">Opening Song {{ opening_song }}</div>

    {% for sec in sections %}
      <div class="mwb-section">
        <h3>{{ sec.section }}</h3>
        {% for item in sec.items %}
          <div class="mwb-item"><span class="mwb-num">{{ item.num }}.</span> {{ item.title }} <span class="mwb-item-time">({{ item.time }})</span></div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
</div>

<div class="title_bar">
  <img class="image" src="/images/plugins/trmnl--render.svg" alt="TRMNL Logo">
  <span class="title">Life &amp; Ministry Meeting</span>
  <span class="instance">{{ week_label }}</span>
</div>
